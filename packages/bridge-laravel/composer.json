{
  "name": "pdf-invoices/laravel",
  "description": "Laravel bridge for pdf-invoices/core.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "pdf-invoices/core": "*",
    "illuminate/contracts": "^12.0 || ^13.0",
    "illuminate/support": "^12.0 || ^13.0"
  },
  "autoload": {
    "psr-4": {
      "PdfInvoices\\Laravel\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "PdfInvoices\\Laravel\\PdfInvoicesServiceProvider"
      ],
      "aliases": {
        "PdfInvoices": "PdfInvoices\\Laravel\\Facade\\PdfInvoices"
      }
    }
  }
}

