{
  "name": "pdf-invoices/core",
  "description": "Framework-independent PDF invoice generation core.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "suggest": {
    "dompdf/dompdf": "Enable the optional Dompdf engine adapter.",
    "twig/twig": "Enable Twig rendering through an optional adapter."
  },
  "autoload": {
    "psr-4": {
      "PdfInvoices\\Core\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PdfInvoices\\Core\\Tests\\": "tests/"
    }
  }
}

